---
import AIAssistant from '../components/AIAssistant.astro';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>IBRAHIM | ARCHIVE</title>
    <style>
      body {
        background-color: #050505;
        background-image: radial-gradient(circle at 50% -20%, rgba(217, 70, 239, 0.15), rgba(5, 5, 5, 0) 60%);
      }
    </style>
  </head>
  <body class="text-white min-h-screen flex flex-col font-sans antialiased">
    
    <div class="w-full h-[1px] bg-zinc-900"></div>

    <header class="w-full max-w-[1600px] mx-auto px-6 md:px-12 py-6 flex justify-between items-center border-b border-zinc-900">
      <div class="text-xs uppercase tracking-[0.3em] font-medium text-zinc-400">
        Selected Works <span class="text-zinc-600">©2026</span>
      </div>
      <div class="text-sm font-bold tracking-[0.4em] text-white">
        IBRAHIM
      </div>
      <nav class="flex gap-8 text-xs uppercase tracking-[0.3em] text-zinc-400">
        <a href="/" class="hover:text-[#D946EF] transition-colors">Home</a>
        <a href="/director" class="hover:text-[#D946EF] transition-colors">Director App</a>
        <a href="/fintech" class="hover:text-[#D946EF] transition-colors">Fintech App</a>
        <a href="/arcade" class="hover:text-[#D946EF] transition-colors">Arcade</a>
        <a href="/about" class="hover:text-[#D946EF] transition-colors">About</a>
      </nav>
    </header>

    <main class="w-full max-w-[1600px] mx-auto px-6 md:px-12 flex-grow flex flex-col">
      
      <section class="py-24 md:py-36 border-b border-zinc-900">
        <h1 class="text-5xl md:text-8xl font-black tracking-tighter uppercase leading-none">
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#D946EF] via-[#e276f7] to-white">
            Ibrahim Archive
          </span>
        </h1>
      </section>

      <section class="grid grid-cols-1 md:grid-cols-3 border-b border-zinc-900">
        
        <div class="border-b md:border-b-0 md:border-r border-zinc-900 p-6 md:p-8 hover:bg-zinc-950/40 transition-all group cursor-pointer">
          <div class="aspect-[4/5] bg-zinc-900 w-full rounded-sm overflow-hidden relative">
            <img 
              src="/project1.png" 
              alt="Project Visual" 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
            />
            <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </div>
        </div>

        <div class="border-b md:border-b-0 md:border-r border-zinc-900 p-6 md:p-8 hover:bg-zinc-950/40 transition-all group cursor-pointer">
          <div class="aspect-[4/5] bg-zinc-900 w-full rounded-sm overflow-hidden relative">
            <img 
              src="/project2.png" 
              alt="Project Visual" 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
            />
            <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </div>
        </div>

        <div class="p-6 md:p-8 hover:bg-zinc-950/40 transition-all group cursor-pointer">
          <div class="aspect-[4/5] bg-zinc-900 w-full rounded-sm overflow-hidden relative">
            <img 
              src="/project3.png" 
              alt="Project Visual" 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
            />
            <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </div>
        </div>

      </section>
    </main>

    <footer class="w-full max-w-[1600px] mx-auto px-6 md:px-12 py-8 flex justify-between items-center text-[10px] uppercase tracking-[0.2em] text-zinc-600">
      <div>Built with Astro & Tailwind</div>
      <div>All Rights Reserved</div>
    </footer>

    {/* The AI Assistant component is now cleanly injected at the layout level */}
    <AIAssistant />

  </body>
</html>