---
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>ABOUT | IBRAHIM</title>
    <style>
      body {
        background-color: #050505;
        background-image: radial-gradient(circle at 50% -20%, rgba(217, 70, 239, 0.15), rgba(5, 5, 5, 0) 60%);
      }
    </style>
  </head>
  <body class="text-white min-h-screen flex flex-col font-sans antialiased">
    
    <div class="w-full h-[1px] bg-zinc-900"></div>

    <header class="w-full max-w-[1600px] mx-auto px-6 md:px-12 py-6 flex justify-between items-center border-b border-zinc-900">
      <div class="text-xs uppercase tracking-[0.3em] font-medium text-zinc-400">
        Get In Touch <span class="text-zinc-600">©2026</span>
      </div>
      <div class="text-sm font-bold tracking-[0.4em] text-white">
        IBRAHIM
      </div>
      <nav class="flex gap-8 text-xs uppercase tracking-[0.3em] text-zinc-400">
        <a href="/" class="hover:text-[#D946EF] transition-colors">Home</a>
        <a href="/director" class="hover:text-[#D946EF] transition-colors">Director App</a>
        <a href="/fintech" class="hover:text-[#D946EF] transition-colors">Fintech App</a>
        <a href="/arcade" class="hover:text-[#D946EF] transition-colors">Arcade</a>
        <a href="/about" class="hover:text-[#D946EF] transition-colors">About</a>
      </nav>
    </header>

    <main class="w-full max-w-[1600px] mx-auto px-6 md:px-12 flex-grow flex flex-col justify-between py-16 md:py-24">
      
      <section class="max-w-5xl mt-8">
        <p class="text-4xl md:text-6xl font-bold tracking-tight leading-[1.15] text-zinc-100">
          Digital content creator & designer providing <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#D946EF] to-white font-extrabold">integrated solutions</span> for visual identities, complete project execution, and cinematic experiences.
        </p>
      </section>

      <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-zinc-900 border border-zinc-900 mt-16 md:mt-24 rounded-sm overflow-hidden">
        
        <a 
          href="https://wa.me/966534657849" 
          target="_blank" 
          class="bg-[#080808] p-8 md:p-10 flex flex-col justify-between group hover:bg-zinc-950/40 transition-all duration-500 relative overflow-hidden h-[220px]"
        >
          <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-[#D946EF] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="flex justify-between items-center">
            <span class="text-[10px] uppercase tracking-[0.3em] text-zinc-500 group-hover:text-zinc-300 transition-colors">Direct Chat</span>
            <span class="text-xs font-mono text-[#D946EF] opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-x-2 group-hover:translate-x-0">→</span>
          </div>
          <h2 class="text-2xl font-bold tracking-tight text-zinc-300 group-hover:text-white transition-colors">
            WhatsApp
          </h2>
        </a>

        <a 
          href="mailto:aalkbsy956@gmail.com" 
          class="bg-[#080808] p-8 md:p-10 flex flex-col justify-between group hover:bg-zinc-950/40 transition-all duration-500 relative overflow-hidden h-[220px]"
        >
          <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-white to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="flex justify-between items-center">
            <span class="text-[10px] uppercase tracking-[0.3em] text-zinc-500 group-hover:text-zinc-300 transition-colors">Inquiries</span>
            <span class="text-xs font-mono text-white opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-x-2 group-hover:translate-x-0">→</span>
          </div>
          <h2 class="text-2xl font-bold tracking-tight text-zinc-300 group-hover:text-white transition-colors">
            Email Me
          </h2>
        </a>

        <a 
          href="https://ib941.github.io/Professional-Archive/index.html" 
          target="_blank" 
          class="bg-[#080808] p-8 md:p-10 flex flex-col justify-between group hover:bg-zinc-950/40 transition-all duration-500 relative overflow-hidden h-[220px]"
        >
          <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-[#D946EF] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="flex justify-between items-center">
            <span class="text-[10px] uppercase tracking-[0.3em] text-zinc-500 group-hover:text-zinc-300 transition-colors">Code Repo</span>
            <span class="text-xs font-mono text-[#D946EF] opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-x-2 group-hover:translate-x-0">→</span>
          </div>
          <h2 class="text-2xl font-bold tracking-tight text-zinc-300 group-hover:text-white transition-colors">
            Core Archive
          </h2>
        </a>

        <a 
          href="https://ibrahim-solutions-center.streamlit.app/" 
          target="_blank" 
          class="bg-[#080808] p-8 md:p-10 flex flex-col justify-between group hover:bg-zinc-950/40 transition-all duration-500 relative overflow-hidden h-[220px]"
        >
          <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-white to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="flex justify-between items-center">
            <span class="text-[10px] uppercase tracking-[0.3em] text-zinc-500 group-hover:text-zinc-300 transition-colors">AI Infrastructure</span>
            <span class="text-xs font-mono text-white opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-x-2 group-hover:translate-x-0">→</span>
          </div>
          <h2 class="text-2xl font-bold tracking-tight text-zinc-300 group-hover:text-white transition-colors">
            AI Solutions
          </h2>
        </a>

      </section>

    </main>

    <footer class="w-full max-w-[1600px] mx-auto px-6 md:px-12 py-8 flex justify-between items-center text-[10px] uppercase tracking-[0.2em] text-zinc-600 border-t border-zinc-900">
      <div>Built with Astro & Tailwind</div>
      <div>All Rights Reserved</div>
    </footer>

  </body>
</html>